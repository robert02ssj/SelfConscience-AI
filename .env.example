# Copy this file to .env and fill in your credentials.

# Choose the LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic API key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (defaults: gpt-4o-mini for OpenAI, claude-3-haiku-20240307 for Anthropic)
# LLM_MODEL=gpt-4o-mini

# Directory where ChromaDB will persist its data (default: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db

# Seconds of user inactivity before entering Reflection Mode (default: 30)
# IDLE_TIMEOUT=30

# Seconds of additional inactivity before entering Sleep/Dream Mode (default: 90)
# SLEEP_TIMEOUT=90
